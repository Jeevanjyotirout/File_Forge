# ════════════════════════════════════════════════════════════
#  FileForge – Environment Configuration
#  Copy to .env and fill in values before running.
#
#  cp .env.example .env
# ════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────

# App environment: development | production
APP_ENV=development

# Set to 1 to enable verbose logging
DEBUG=0

# Secret key for any JWT/session signing
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Comma-separated list of allowed CORS origins
# Use * in development, explicit domains in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80


# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis broker URL (Celery uses this for task queue)
REDIS_URL=redis://redis:6379/0

# Redis result backend URL (Celery stores task results here)
REDIS_RESULT_URL=redis://redis:6379/1


# ── Storage ───────────────────────────────────────────────────────────────────

# Absolute path to temporary upload directory inside the container
TEMP_DIR=/app/storage/temp

# Absolute path to processed output files directory
OUTPUT_DIR=/app/storage/output

# How many seconds before processed files are deleted (default: 3600 = 1 hour)
FILE_TTL_SECONDS=3600

# Maximum upload size in megabytes
MAX_UPLOAD_MB=500


# ── Celery ────────────────────────────────────────────────────────────────────

# Soft time limit (seconds) – sends SoftTimeLimitExceeded
CELERY_TASK_SOFT_TIME_LIMIT=270

# Hard time limit (seconds) – kills the task
CELERY_TASK_TIME_LIMIT=300

# Max worker processes per Celery child before recycling
CELERY_WORKER_MAX_TASKS=200


# ── Flower (Celery monitoring UI) ────────────────────────────────────────────

FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower-password


# ── Rate limiting (optional, enforced in API) ────────────────────────────────

# Maximum requests per minute per IP (0 = disabled)
RATE_LIMIT_PER_MINUTE=60


# ── External Integrations (optional) ─────────────────────────────────────────

# OpenAI API key (for AI-enhanced OCR / document summarization)
OPENAI_API_KEY=

# AWS S3 (optional – persist output files to S3 instead of local disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Sentry DSN for error tracking
SENTRY_DSN=
